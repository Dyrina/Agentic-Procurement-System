# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# Google Gemini API Key
GOOGLE_API_KEY=your-google-api-key

# Gmail OAuth (download credentials.json from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_SENDER_EMAIL=your-gmail@gmail.com

# Model tiers (optional — these are the defaults)
# MODEL_FAST=gemini-3.1-flash-lite
# MODEL_SMART=gemini-3.5-flash

# LangSmith tracing (optional — set both to watch live agent traces at smith.langchain.com)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key
