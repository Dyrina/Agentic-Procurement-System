# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Google Gemini API Key
GOOGLE_API_KEY=your-google-api-key

# Model tiers (optional — these are the defaults)
# fast: classification/extraction gated by schemas or human confirmation
# smart: judgment where errors cost money or are user-visible (quotes, evaluation, reports)
# MODEL_FAST=gemini-3.1-flash-lite
# MODEL_SMART=gemini-3.5-flash

# LangSmith tracing (optional — set both to watch live agent traces at smith.langchain.com)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-key

# Gmail OAuth (download credentials.json from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=backend/tokens/credentials.json
GMAIL_TOKEN_PATH=backend/tokens/token.json
GMAIL_SENDER_EMAIL=your-gmail@gmail.com
